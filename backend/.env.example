# ============================================================
# Campus Pocket – Environment Variables
# ============================================================
# 1. Copy this file and rename the copy to ".env"
# 2. Replace the placeholder values with your real Supabase keys
# 3. Find these values in: Supabase Dashboard → Settings → API
# ============================================================

# Your Supabase project URL (looks like https://abcdefg.supabase.co)
SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (a long string starting with eyJ...)
SUPABASE_ANON_KEY=your-anon-key-here

# Your Supabase service_role key (needed by createAuthUsers.js)
# Find it in: Supabase Dashboard → Settings → API → service_role (secret)
# ⚠️ Keep this SECRET – never expose it in frontend code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
