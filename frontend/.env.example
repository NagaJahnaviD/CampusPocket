# Supabase connection – get these from your Supabase project settings
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Gemini AI for student insights
# EXPO_PUBLIC_GEMINI_API_KEY=your-gemini-key-here

# UPI Payment – set your UPI ID to receive fee payments
# EXPO_PUBLIC_UPI_ID=yourname@upi
# EXPO_PUBLIC_MERCHANT_NAME=Campus Pocket
